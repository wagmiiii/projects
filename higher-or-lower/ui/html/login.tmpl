<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Login - Higher or Lower</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/static/css/style.css"/>
</head>
<body>
    <main class="game-container">
        <div class="game-card">
            <h1>welcome to HotSeat</h1>
            <p class="message">tell us your name.</p>
            
            <form action="/login" method="POST">
                <div class="input-group">
                    <label for="username">username</label>
                    <input id="username" name="username" placeholder="" required autofocus type="text"/>
                </div>
                <button class="btn" type="submit">start playing</button>
            </form>
        </div>
    </main>
</body>
</html>